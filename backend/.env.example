# ============================================
# LUXE Store - Variables de Entorno
# Copia este archivo como .env y ajusta los valores
# ============================================

# Base de datos PostgreSQL
BD_HOST=localhost
BD_PUERTO=5432
BD_NOMBRE=luxe_store
BD_USUARIO=postgres
BD_CONTRASENA=tu_contrasena_aqui

# JWT
JWT_SECRETO=tu_secreto_jwt_super_seguro_aqui
JWT_EXPIRACION=24h

# Puertos de microservicios
PUERTO_AUTH=3001
PUERTO_PRODUCTOS=3002
PUERTO_CARRITO=3003
PUERTO_ORDENES=3004
PUERTO_GATEWAY=3000
PUERTO_FRONTEND=8080
